# Copy this file to .env and fill in your values.
# The docker-compose.yml reads this file automatically.

# PostgreSQL + TimescaleDB connection string
DATABASE_URL=postgresql+asyncpg://srvwatch:srvwatch@localhost:5432/srvwatch

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# How often (seconds) to poll each agent
POLL_INTERVAL_SECONDS=10

# How many days of data to retain in the database
DATA_RETENTION_DAYS=7

# Port the central server listens on
CENTRAL_PORT=8000
